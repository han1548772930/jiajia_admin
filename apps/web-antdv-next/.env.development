# Build target for development override: admin | workflow | dashboard | b2b
VITE_APP_TARGET=workflow

# Dev server port
VITE_PORT=5999

VITE_BASE=/

# API base URL
VITE_GLOB_API_URL=http://127.0.0.1:5002/api

# Enable Nitro Mock service
VITE_NITRO_MOCK=true

# Enable Vite devtools
VITE_DEVTOOLS=false

# Inject global loading
VITE_INJECT_APP_LOADING=true
